<Window x:Class="PomodoroApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="K-Pomodoro" Height="460" Width="400" Icon="icon.png"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Window.Resources>
        <!-- 圓角按鈕樣式 -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#2E2E46"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 圓角進度條樣式 -->
        <Style x:Key="CycleBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border x:Name="PART_Track" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主卡片（圓角 + 陰影） -->
    <Border CornerRadius="20" Background="#1C1C2E" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="8" Color="#000000" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 標題列（可拖曳 + 關閉按鈕） -->
            <Border Grid.Row="0" CornerRadius="20,20,0,0" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="22,0,12,0">
                    <TextBlock x:Name="TxtTitle" Text="K-POMODORO" Foreground="#7070A0" FontSize="10"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <!-- 設定按鈕 -->
                        <Button Width="28" Height="28" Margin="0,0,4,0"
                                Click="BtnSettings_Click" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="14">
                                        <TextBlock Text="⚙" Foreground="#9090B8" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 關閉按鈕 -->
                        <Button Width="28" Height="28" Click="BtnClose_Click" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="14">
                                        <TextBlock Text="✕" Foreground="#9090B8" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主內容 -->
            <StackPanel Grid.Row="1" Margin="30,0,30,32" VerticalAlignment="Center">

                <!-- 狀態徽章 -->
                <Border x:Name="BadgeBorder" HorizontalAlignment="Center"
                        CornerRadius="14" Padding="20,7" Margin="0,0,0,22"
                        Background="#2A1515">
                    <TextBlock x:Name="TxtStatus" Text="Ready to Work"
                               Foreground="#E85D50" FontSize="13" FontWeight="SemiBold"/>
                </Border>

                <!-- 計時器 -->
                <TextBlock x:Name="TxtTimer" Text="25:00"
                           FontSize="78" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- 操作按鈕 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                    <Button x:Name="BtnStart" Content="▶  Start"
                            Width="118" Height="44" Margin="6,0"
                            Background="#E85D50"
                            Style="{StaticResource PillButton}"
                            Click="BtnStart_Click"/>
                    <Button x:Name="BtnReset" Content="↺  Reset"
                            Width="118" Height="44" Margin="6,0"
                            Background="#252540"
                            Style="{StaticResource PillButton}"
                            Click="BtnReset_Click"/>
                </StackPanel>

                <!-- 工作日誌按鈕 -->
                <Button Content="📋  Work Log" HorizontalAlignment="Center"
                        Width="120" Height="30" Margin="0,0,0,16"
                        Background="Transparent" Foreground="#555575"
                        FontSize="11" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnWorkLog_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="15">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1E1E30"/>
                                    <Setter Property="Foreground" Value="#9090C0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 循環進度 -->
                <TextBlock Text="CYCLES" Foreground="#7070A0" FontSize="10"
                           FontWeight="Bold" HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <UniformGrid x:Name="CyclesGrid" Rows="1" Columns="5">
                    <ProgressBar x:Name="Bar1" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0"/>
                    <ProgressBar x:Name="Bar2" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0"/>
                    <ProgressBar x:Name="Bar3" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0"/>
                    <ProgressBar x:Name="Bar4" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0"/>
                    <ProgressBar x:Name="Bar5" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0"/>
                    <ProgressBar x:Name="Bar6" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0" Visibility="Collapsed"/>
                    <ProgressBar x:Name="Bar7" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0" Visibility="Collapsed"/>
                    <ProgressBar x:Name="Bar8" Style="{StaticResource CycleBarStyle}"
                                 Foreground="#E85D50" Margin="4,0" Visibility="Collapsed"/>
                </UniformGrid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
