<Window x:Class="PomodoroApp2.WorkLogListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Work Log List" Height="480" Width="420"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#1C1C2E" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Color="#000000" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 標題列 -->
            <Grid Grid.Row="0" Margin="28,20,20,12"
                  MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="WORK LOG" Foreground="#D0D0E0" FontSize="10"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="24" Height="24" Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="12">
                                <TextBlock Text="✕" Foreground="#9090B8" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 日誌清單 -->
            <ScrollViewer Grid.Row="1" Margin="16,0,16,0"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Background="#252540"
                                    Margin="0,0,0,8" Padding="14,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <!-- 完成狀態徽章 -->
                                        <Border HorizontalAlignment="Left"
                                                CornerRadius="8" Padding="8,3"
                                                Background="{Binding StatusColor}">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusFg}"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <!-- cycles + 日期 -->
                                        <StackPanel HorizontalAlignment="Right"
                                                    Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CyclesText}"
                                                       Foreground="#A0C0C0" FontSize="11" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding DateText}"
                                                       Foreground="#A0A0D0" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Comment -->
                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="{Binding Comment}"
                                                   Foreground="#C0C0E0" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                        <Border CornerRadius="6" Background="#1A1A30"
                                                Padding="8,5" Margin="0,6,0,0"
                                                Visibility="{Binding HasNextHint, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▶ " Foreground="#B0B0D0" FontSize="11"/>
                                                <TextBlock Text="{Binding NextHint}"
                                                           Foreground="#D0D0E0" FontSize="11"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 無記錄提示 -->
            <TextBlock x:Name="TxtEmpty" Grid.Row="1"
                       Text="No work logs yet." Foreground="#9090B0"
                       FontSize="13" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Visibility="Collapsed"/>

            <!-- 底部關閉 -->
            <Button Grid.Row="2" Content="Close"
                    Width="100" Height="34" Margin="0,12,0,20"
                    HorizontalAlignment="Center"
                    Background="#252540" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
