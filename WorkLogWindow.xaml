<Window x:Class="PomodoroApp2.WorkLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Work Log" Height="450" Width="360"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="16" Background="#1C1C2E" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Color="#000000" Opacity="0.55"/>
        </Border.Effect>

        <StackPanel Margin="28,22,28,22">

            <!-- 標題列（可拖曳） -->
            <Grid Margin="0,0,0,16" MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="WORK LOG" Foreground="#D0D0E0" FontSize="10"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtDate" HorizontalAlignment="Right"
                           Foreground="#A0A0D0" FontSize="10" VerticalAlignment="Center"/>
            </Grid>

            <!-- 完成提示 -->
            <Border x:Name="CompletionBadge" CornerRadius="10" Background="#1A2A1A" Padding="12,8" Margin="0,0,0,14">
                <TextBlock x:Name="TxtCompletionHeader" Text="🎉  All Cycles Completed!" Foreground="#4ECDC4"
                           FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </Border>

            <!-- Comment 輸入 -->
            <TextBlock Text="Today's Notes" Foreground="#A5A5D5" FontSize="11" Margin="0,0,0,6"/>
            <Border CornerRadius="10" Background="#252540" Padding="2">
                <TextBox x:Name="TxtComment"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White" FontSize="13" CaretBrush="White"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Height="80" VerticalScrollBarVisibility="Auto"
                         Padding="10,8" VerticalContentAlignment="Top"/>
            </Border>

            <!-- 下次工作提示 -->
            <TextBlock Text="Next Session Hint" Foreground="#A5A5D5" FontSize="11" Margin="0,12,0,6"/>
            <Border CornerRadius="10" Background="#252540" Padding="2">
                <TextBox x:Name="TxtNextHint"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White" FontSize="13" CaretBrush="White"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Height="70" VerticalScrollBarVisibility="Auto"
                         Padding="10,8" VerticalContentAlignment="Top"/>
            </Border>

            <!-- 按鈕 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                <Button x:Name="BtnDone" Content="✔  Done" Width="110" Height="38" Margin="6,0"
                        Background="#4ECDC4" Foreground="#0F2220"
                        FontSize="13" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnCompleted_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="19">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="✘  Incomplete" Width="110" Height="38" Margin="6,0"
                        Background="#E85D50" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnIncomplete_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="19">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
