<Window x:Class="PomodoroApp2.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="280" Width="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="16" Background="#1C1C2E" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Color="#000000" Opacity="0.55"/>
        </Border.Effect>

        <StackPanel Margin="28,22,28,22">

            <!-- 標題列 -->
            <Grid Margin="0,0,0,20">
                <TextBlock Text="SETTINGS" Foreground="#7070A0" FontSize="10"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="24" Height="24" Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="12">
                                <TextBlock Text="✕" Foreground="#9090B8" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 循環數設定 -->
            <TextBlock Text="Cycle Count" Foreground="#9090C0" FontSize="12"
                       Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,6">
                <Slider x:Name="SliderCycles"
                        Minimum="2" Maximum="8" TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="5"
                        Foreground="#E85D50"
                        ValueChanged="SliderCycles_ValueChanged"/>
                <TextBlock x:Name="TxtCycleValue"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           Margin="0,-28,0,0"/>
            </Grid>

            <Grid Margin="0,2,0,0">
                <TextBlock Text="2" Foreground="#555575" FontSize="10" HorizontalAlignment="Left"/>
                <TextBlock Text="8" Foreground="#555575" FontSize="10" HorizontalAlignment="Right"/>
            </Grid>

            <!-- 版號 -->
            <TextBlock x:Name="TxtVersion" Foreground="#444466" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>

            <!-- 確認 / 取消 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="OK" Width="90" Height="36" Margin="6,0"
                        Background="#E85D50" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnOk_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Cancel" Width="90" Height="36" Margin="6,0"
                        Background="#252540" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
